# ── Build output (regenerate with scripts/build-linux.sh / build-macos.sh / build-win.bat) ──
/build/
/dist/
*.spec.bak

# ── Python caches / local venvs ──
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# ── Superpowers SDD scratch (ledger, review diffs) — process artifacts, never source ──
.superpowers/

# ── EDL/Firehose run log (fh_loader writes this to the cwd) ──
/port_trace.txt

# ── SECRETS — cas-config.json holds the NAS app password (obfuscated). NEVER commit. ──
cas-config.json
*.local.json

# ── Operator-supplied runtime + local data — ALL grouped under data/ (huge; on the NAS, not in git). ──
#   data/ holds: profiles, Apps, ES-DE (+ ES-DE/downloaded_media), retroarch-cores, Bios, payloads,
#   downloaded_media (master scrape pool), device-firmwares. The app reads them via APPDIR/data/.
/data/
/golden_backup_*/

# ── Raw brand source (large binaries) ──
/assets/branding/

# ── Legacy runner output (scripts/run.sh / run.ps1 write diagnostic reports here) ──
/scripts/results/

# ── Device tools + firmware (the operator supplies these per-PC; not source) ──
/platform-tools/
/windows-kit/
/provision/root/firmware/
**/magisk-patch/

# ── Binary blobs anywhere ──
*.img
*.apk
*.dll
*.exe
*.so
*.bin
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# ── Camera / media / reports (safety — never publish) ──
*.mp4
*.pic
*.mov
*.pbix

# ── Magisk boot-patch toolkit — MUST ship (un-ignore, LAST so it beats the rules above) ──
#   provision/root/magisk-patch/ (aarch64 magiskboot + magiskinit + magisk + init-ld + Magisk's
#   boot_patch.sh/util_functions.sh + stub.apk) is a FIXED, device-agnostic runtime asset the root
#   flow reads from BUNDLE/provision/root/magisk-patch/ and pushes to the device to patch init_boot.
#   Unlike firmware/APKs (operator-supplied, external in data/), this is small (~1.5 MB) and required
#   for cas to root at all, so it is bundled INTO the frozen app and therefore must be in git — a clean
#   checkout (what CI freezes) has no other source for it. These negations must sit AFTER **/magisk-patch/
#   and *.apk above (last matching pattern wins; the dir must be re-included before its files can be).
!/provision/root/magisk-patch/
!/provision/root/magisk-patch/**
