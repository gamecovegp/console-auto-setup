# init.cas-grant.rc -- injected into the boot ramdisk via overlay.d. Runs cas-grant.sh once as root
# after boot to pre-write the MagiskSU shell-allow policy (zero-touch adb root, no Grant dialog).
# seclabel u:r:magisk:s0 puts the service in Magisk's unconfined domain so it can talk to magiskd.
#
# Path: magiskinit MOVES the overlay.d/ contents to the root (mv_path("overlay.d","/")), so the script
# lands at /cas-grant.sh -- NOT /overlay.d/cas-grant.sh. Referencing the wrong path made the service a
# no-op (it exec'd a file that didn't exist), so the marker never appeared and su was never granted.
# Exec whichever path is actually present so it works whether or not this magiskinit relocates overlay.d.
service cas_grant /system/bin/sh -c "for f in /cas-grant.sh /overlay.d/cas-grant.sh; do [ -f $f ] && exec /system/bin/sh $f; done"
    user root
    group root
    seclabel u:r:magisk:s0
    oneshot
    disabled

on property:sys.boot_completed=1
    start cas_grant
